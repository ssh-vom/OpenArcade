# Shared runtime configuration for OpenArcade services.
OPENARCADE_CONFIG_PATH=/var/lib/openarcade/config.json
OPENARCADE_HID_MODE_PATH=/var/lib/openarcade/hid_mode.json
OPENARCADE_PAIRING_MODE_PATH=/var/lib/openarcade/pairing_mode.json
OPENARCADE_CONFIG_MODE_PATH=/var/lib/openarcade/config_mode.json
OPENARCADE_HID_MODE_PIN=4
OPENARCADE_HID_MODE_HOLD_SECONDS=3.0
OPENARCADE_PAIRING_MODE_PIN=17
OPENARCADE_PAIRING_MODE_HOLD_SECONDS=1.5
OPENARCADE_CONFIG_MODE_CHORD_SECONDS=2.0
OPENARCADE_CONFIG_MODE_CHORD_WINDOW_SECONDS=0.35
OPENARCADE_CONFIG_MODE_ORCHESTRATOR_POLL_INTERVAL=0.5
OPENARCADE_CONFIG_AP_SSID=OpenArcade-Config
OPENARCADE_CONFIG_AP_PSK=openarcade
OPENARCADE_CONFIG_AP_INTERFACE=wlan0
OPENARCADE_CONFIG_AP_ADDR=192.168.4.1/24
OPENARCADE_CONFIG_PORTAL_HOST=0.0.0.0
OPENARCADE_CONFIG_PORTAL_PORT=8080
OPENARCADE_CONFIG_PORTAL_STATIC_DIR=/opt/openarcade/app/config_app/dist
OPENARCADE_CONFIG_PORTAL_INDEX_FILE=lite.html
OPENARCADE_HOSTNAME=thiscoolpi
OPENARCADE_DISPLAY_I2C_PORT=1
OPENARCADE_DISPLAY_I2C_ADDRESS=0x3C
OPENARCADE_DISPLAY_POLL_INTERVAL=1.0
OPENARCADE_DISPLAY_ROTATE=0
OPENARCADE_GADGET_POLL_INTERVAL=0.5
OPENARCADE_SWITCH_GADGET_ENABLED=1
OPENARCADE_SWITCH_GADGET_VID=0x0F0D
OPENARCADE_SWITCH_GADGET_PID=0x0092
PYTHONUNBUFFERED=1
