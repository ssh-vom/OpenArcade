# Shared runtime configuration for OpenArcade services.
OPENARCADE_CONFIG_PATH=/var/lib/openarcade/config.json
OPENARCADE_DISPLAY_GPIO_CHIP=/dev/gpiochip0
OPENARCADE_DISPLAY_SPI_PORT=0
OPENARCADE_DISPLAY_SPI_DEVICE=0
OPENARCADE_DISPLAY_DC_PIN=24
OPENARCADE_DISPLAY_RST_PIN=25
OPENARCADE_DISPLAY_SPI_SPEED_HZ=8000000
OPENARCADE_DISPLAY_POLL_INTERVAL=1.0
OPENARCADE_DISPLAY_ROTATE=0
PYTHONUNBUFFERED=1
